<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
			 x:Class="AwsCredentialsManager.MainPage">

	<ScrollView>
		<VerticalStackLayout x:Name="MainLayout" Padding="25" Spacing="25" IsVisible="False">

			<Label Text="Select credentials" />

			<Picker x:Name="CredentialsPicker"
					ItemsSource="{Binding Accounts}"
					ItemDisplayBinding="{Binding Name}"
					SelectedItem="{Binding SelectedAccount, Mode = TwoWay}" />

			<Label x:Name="InputLabel" Text="Paste credentials" />

			<Editor x:Name="InputEditor" AutoSize="TextChanges" MinimumHeightRequest="200">
				<Editor.Behaviors>
					<toolkit:SelectAllTextBehavior />
				</Editor.Behaviors>
			</Editor>

			<Button
				x:Name="SaveButton"
				Text="Save Credentials"
				SemanticProperties.Hint="Saves AWS credentials to file"
				Clicked="OnSaveClicked"
				HorizontalOptions="Fill" />

		</VerticalStackLayout>
	</ScrollView>

</ContentPage>
